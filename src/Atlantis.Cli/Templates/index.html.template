<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ProjectName}}</title>
    <script src="atlantis.js"></script>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            max-width: 800px;
            margin: 2rem auto;
            padding: 0 1rem;
        }
        h1 { color: #333; }
        .demo {
            background: #f5f5f5;
            padding: 1rem;
            border-radius: 8px;
            margin: 1rem 0;
        }
        button {
            background: #0066cc;
            color: white;
            border: none;
            padding: 0.5rem 1rem;
            border-radius: 4px;
            cursor: pointer;
        }
        button:hover { background: #0055aa; }
        #output {
            margin-top: 1rem;
            padding: 0.5rem;
            background: #e8e8e8;
            border-radius: 4px;
            min-height: 1.5rem;
        }
    </style>
</head>
<body>
    <h1>Welcome to {{ProjectName}}</h1>
    <p>Your Atlantis app is running! Edit this file at <code>src/frontend/index.html</code>.</p>
    
    <div class="demo">
        <h3>Try the API</h3>
        <input type="text" id="nameInput" placeholder="Enter your name" value="World">
        <button onclick="sayHello()">Say Hello</button>
        <div id="output"></div>
    </div>

    <script>
        async function sayHello() {
            const name = document.getElementById('nameInput').value;
            const result = await atlantis.Api.Hello(name);
            document.getElementById('output').textContent = result;
        }
    </script>
</body>
</html>
